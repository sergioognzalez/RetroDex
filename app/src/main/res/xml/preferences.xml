<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory app:title="@string/pref_category_appearance">
        <SwitchPreferenceCompat
            app:key="dark_theme"
            app:title="@string/pref_theme_title"
            app:summary="@string/pref_theme_summary"
            app:defaultValue="true" />
    </PreferenceCategory>

    <PreferenceCategory app:title="@string/pref_category_notifications">
        <SwitchPreferenceCompat
            app:key="notifications_enabled"
            app:title="@string/pref_notifications_title"
            app:summary="@string/pref_notifications_summary"
            app:defaultValue="true" />
    </PreferenceCategory>

</PreferenceScreen>
