<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_bg_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Selector de imagen -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:background="@drawable/bg_image_placeholder">

            <ImageView
                android:id="@+id/iv_add_image"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop" />

            <TextView
                android:id="@+id/tv_add_emoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:textSize="64sp"
                android:text="🖼️" />

            <!-- ImageButton para seleccionar imagen -->
            <ImageButton
                android:id="@+id/btn_pick_image"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="bottom|end"
                android:layout_margin="12dp"
                android:background="@color/color_neon_pink"
                android:src="@android:drawable/ic_menu_camera"
                android:tint="@color/white"
                android:contentDescription="@string/btn_select_image"
                android:padding="10dp" />

        </FrameLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Toca el icono de cámara para seleccionar imagen de galería"
            android:textSize="11sp"
            android:textColor="@color/color_text_hint"
            android:gravity="center"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="20dp" />

        <!-- Nombre -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/field_name"
            style="@style/RetroDex.TextInput"
            android:layout_marginBottom="12dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapWords"
                android:textColor="@color/color_text_primary"
                android:maxLines="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Spinner Década -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/field_decade"
            android:textColor="@color/color_text_secondary"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <Spinner
            android:id="@+id/spinner_decade"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_card_character"
            android:paddingHorizontal="12dp"
            android:spinnerMode="dropdown"
            android:popupBackground="@color/color_surface_dark"
            android:layout_marginBottom="12dp" />

        <!-- Spinner Categoría -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/field_category"
            android:textColor="@color/color_text_secondary"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <Spinner
            android:id="@+id/spinner_category"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_card_character"
            android:paddingHorizontal="12dp"
            android:spinnerMode="dropdown"
            android:popupBackground="@color/color_surface_dark"
            android:layout_marginBottom="12dp" />

        <!-- Origen -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/field_origin"
            style="@style/RetroDex.TextInput"
            android:layout_marginBottom="12dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_origin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapSentences"
                android:textColor="@color/color_text_primary"
                android:maxLines="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Descripción -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/field_description"
            style="@style/RetroDex.TextInput"
            android:layout_marginBottom="24dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapSentences|textMultiLine"
                android:textColor="@color/color_text_primary"
                android:minLines="3"
                android:maxLines="6"
                android:gravity="top" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Botón Guardar -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save_character"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/btn_save"
            android:textSize="16sp"
            android:fontFamily="monospace"
            app:backgroundTint="@color/color_neon_pink" />

    </LinearLayout>

</ScrollView>
